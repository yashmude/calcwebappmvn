pipeline {
    agent {
        label 'ag-1' 
        }
    environment {
        my_aws_access= credentials('ash-aws-cred')
    }
    tools {
        terraform 'TF-install'
    }
    stages {
        stage('Terraform Init') {
            steps {
                sh 'terraform init'
            }
        }
         stage('Terraform fmt-validate') {
            steps {
                sh '''
                terraform fmt
                terraform validate
                '''
            }
        }
         stage('Terraform plan') {
            steps {
                sh 'terraform plan'
            }
        }
         stage('Terraform APPLY') {
            steps {
                sh 'terraform apply -auto-approve'
            }
        }
    }
}
